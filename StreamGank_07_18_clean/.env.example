# StreamGank Docker Environment Configuration
# Copy this file to .env and fill in your actual values

# =============================================================================
# APPLICATION ENVIRONMENT
# =============================================================================
# Set to 'local' to use hardcoded HeyGen URLs instead of making API calls
# This saves credits during development
# APP_ENV=production  # Use for Production mode with real APIs
APP_ENV=local     # Use for local development mode with hardcoded HeyGen URLs

# =============================================================================
# DATA STORAGE CONFIGURATION
# =============================================================================

# 📁 CHOOSE THE RIGHT PATH FOR YOUR ENVIRONMENT:

# 🖥️  FOR LOCAL DEVELOPMENT (Windows/macOS):
STREAMGANK_DATA_PATH=./docker_volumes
# 
# 🐧 FOR LINUX VM DEPLOYMENT (uncomment and use instead):
# STREAMGANK_DATA_PATH=/var/lib/streamgankvideos
#
# 💡 EXAMPLES:
# Windows:     STREAMGANK_DATA_PATH=./docker_volumes
#              STREAMGANK_DATA_PATH=C:/streamgankvideos-data
# Linux VM:    STREAMGANK_DATA_PATH=/var/lib/streamgankvideos
#              STREAMGANK_DATA_PATH=/opt/streamgankvideos
#              STREAMGANK_DATA_PATH=/home/user/streamgankvideos-data

# This path will contain all persistent data:
# - {path}/assets/     (generated assets)
# - {path}/videos/     (output videos)  
# - {path}/outputs/    (processed outputs)
# - {path}/redis/      (Redis data)
# - {path}/logs/       (application logs)

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_HOST=your-redis-host
REDIS_PORT=your-redis-port
REDIS_PASSWORD=your-redis-password
REDIS_DB=0
# Database selection:
# 0 = Production
# 1 = Development  
# 2 = Testing
# 3 = Staging

# =============================================================================
# SUPABASE DATABASE CONFIGURATION
# =============================================================================
SUPABASE_URL=your-supabase-url
SUPABASE_KEY=your-supabase-key

# =============================================================================
# AI SERVICE CONFIGURATIONS
# =============================================================================

# OpenAI Configuration
OPENAI_API_KEY=your-openai-api-key

# HeyGen Configuration
HEYGEN_API_KEY=your-heygen-api-key

# =============================================================================
# VIDEO PROCESSING SERVICES
# =============================================================================

# Creatomate Configuration
CREATOMATE_API_KEY=your-creatomate-api-key

# Cloudinary Configuration
CLOUDINARY_URL=your-cloudinary-url
CLOUDINARY_CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# Vizard.ai Configuration (AI-Powered Video Clipping)
VIZARD_API_KEY=your-vizard-api-key

# =============================================================================
# APPLICATION SETTINGS
# =============================================================================

# Video Generation Settings
DEFAULT_NUM_MOVIES=3
DEFAULT_SCROLL_SPEED=ultra
STRICT_EXACT_DURATION=true

# Queue Worker Settings
MAX_WORKERS=3                       # Maximum number of concurrent video generation workers (1-5)
ENABLE_CONCURRENT_PROCESSING=true   # Enable multiple jobs to run simultaneously

# Logging Settings
LOG_LEVEL=info

# =============================================================================
# DOCKER-SPECIFIC SETTINGS
# =============================================================================

# Node.js GUI Server
NODE_ENV=production
PORT=3000

# Python Backend
PYTHONPATH=/app
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1      # Set to 0 for debugging/development
